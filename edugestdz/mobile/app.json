{
  "expo": {
    "name": "EduGest DZ",
    "slug": "edugestdz-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E5EBC"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "dz.edugest.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1E5EBC"
      },
      "package": "dz.edugest.mobile"
    },
    "plugins": [
      "expo-secure-store",
      "expo-notifications",
      "expo-localization"
    ]
  }
}
